# LLMode UI — environment variable reference.
#
# Copy this file to .env.local (git-ignored by Vite by default) and uncomment
# the lines you want to override.
#
# VITE_* variables are embedded into the browser bundle at build time.
# Non-VITE_ variables (like VITE_PORT) are only used by the Vite dev server
# itself and never reach the browser.

# ---------------------------------------------------------------------------
# Server port (Node.js only — NOT embedded into the browser bundle)
# ---------------------------------------------------------------------------

# Port for BOTH the dev server (npm run dev) and preview server (npm run preview).
# No VITE_ prefix — Node-only config value, never sent to the browser.
# PORT=3001

# ---------------------------------------------------------------------------
# Daemon connection (browser → daemon)
# ---------------------------------------------------------------------------

# Base URL of the LLMode daemon.
#   - Leave unset (or empty) when using the Vite dev proxy (local dev default).
#     The proxy forwards /api and /v1 to the daemon automatically.
#   - Set this when running the built bundle (npm run preview / production)
#     or when the daemon is on a different host/port than the default.
# VITE_LLMODE_API=http://127.0.0.1:8080

# Bearer token sent with every API request (Authorization: Bearer <token>).
# Must match LLMODE_AUTH_TOKEN set on the daemon.
# Leave unset when the daemon is in localhost-trusted mode (the default).
# VITE_LLMODE_TOKEN=
