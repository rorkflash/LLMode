# LLMode daemon + CLI — environment variable reference.
#
# Copy this file to .env and uncomment the lines you want to override.
# All variables are prefixed LLMODE_ and are read by pydantic-settings
# on top of the YAML config file (env vars win on conflict).
#
# The YAML config file lives at:
#   macOS  → ~/Library/Application Support/llmode/config.yaml
#   Linux  → ~/.local/share/llmode/config.yaml
# Override its location with XDG_DATA_HOME.

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# Address the daemon binds to.
# Use 0.0.0.0 to expose on the local network (combine with LLMODE_AUTH_TOKEN).
# LLMODE_HOST=127.0.0.1

# HTTP port the daemon listens on.
# LLMODE_PORT=8080

# CORS origins allowed to call /api/* and /v1/* from a browser.
# Comma-separated list. Must include the UI's origin when running separately.
# LLMODE_ALLOWED_ORIGINS=["http://localhost:5173"]

# Bearer token for API auth. Unset = localhost-trusted (no auth required).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# LLMODE_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Storage paths
# ---------------------------------------------------------------------------

# Directory for the SQLite DB, logs, and runtime state.
# LLMODE_DATA_DIR=~/Library/Application Support/llmode   # macOS default
# LLMODE_DATA_DIR=~/.local/share/llmode                  # Linux default

# Directory where downloaded model weights are stored.
# LLMODE_MODELS_DIR=~/Library/Application Support/llmode/models

# Path to the ui/ React app (auto-detected from package location by default).
# Set this if you move ui/ somewhere non-standard.
# LLMODE_UI_DIR=/path/to/ui

# ---------------------------------------------------------------------------
# Memory budget (load/unload guard)
# ---------------------------------------------------------------------------

# Maximum fraction of total system RAM LLMode may commit to loaded models.
# LLMODE_RAM_BUDGET_FRACTION=0.8

# Maximum fraction of total GPU VRAM LLMode may commit to loaded models.
# LLMODE_VRAM_BUDGET_FRACTION=0.9

# ---------------------------------------------------------------------------
# Lifecycle
# ---------------------------------------------------------------------------

# Lazy-load a model automatically on its first /v1/* inference request.
# LLMODE_LAZY_LOAD=true

# Unload a model after this many seconds with no requests (0 = never).
# LLMODE_IDLE_TTL_SECONDS=600

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------

# How often (seconds) the metrics collector samples system + model stats.
# LLMODE_METRICS_INTERVAL_SECONDS=2.0

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Root log level: DEBUG | INFO | WARNING | ERROR
# LLMODE_LOG_LEVEL=INFO
